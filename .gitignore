# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

_bmad
.claude
.codex
.cursor
.vscode
_paper
_presentation

# Scarb / Starknet Foundry build artifacts
.snfoundry_cache

# Epicue Deployment Secrets
deployment/*.env
deployment/*.json
deployment/*.log
deployment/starknet-devnet
deployment/*.tar.gz
snfoundry_accounts.json
starknet_open_zeppelin_accounts.json

# Metadata exclusion
Agent.md
claude.md
AGENTS.md
CLAUDE.md
.venv
venv/
node_modules/
portal/dist/
portal/.env.local

# LaTeX build artifacts
*.aux
*.log
*.toc
*.out
*.synctex.gz

# Erlang build outputs
*.beam

# Compiled C++ Binaries for Stone Prover
bin/cpu_air_prover
bin/cpu_air_verifier

# Cairo compilation and VM execution artifacts
daemon/*_compiled.json
daemon/*_trace.json
daemon/*_memory.json
daemon/*_proof.json
daemon/*_public_input.json
daemon/*_private_input.json

# Performance plot outputs
perf/*.pdf