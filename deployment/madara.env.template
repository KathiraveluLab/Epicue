# Epicue Madara Appchain Deployment Environment
# Configured for custom Madara sequencers (L3/L2) running with zero/custom gas.

export EPICUE_DEPLOY_TARGET=madara

# Madara Appchain RPC Endpoint
export STARKNET_RPC=http://madara-sequencer.consortium.org:8000

# Pre-funded Admin/Authority Account Address on the Madara Chain
export STARKNET_ACCOUNT=0x1

# Private Key for the Admin/Authority Account
export STARKNET_PRIVATE_KEY=0x00cdb67c4d5dba94c25d88665f8d68962635a9094e9f4e9f4e9f4e9f4e9f4e9f
